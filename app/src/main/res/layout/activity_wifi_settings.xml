<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="?android:attr/windowBackground"
    android:padding="16dp">

    <!-- 当前连接信息 -->
    <TextView android:id="@+id/tv_current_wifi"
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:text="当前未连接 Wi-Fi"
        android:textColor="?android:attr/textColorPrimary"
        android:textSize="13sp" android:paddingBottom="12dp"/>

    <!-- SSID -->
    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:text="目标 Wi-Fi SSID（车机热点名称）"
        android:textColor="?android:attr/textColorPrimary"
        android:textSize="13sp"
        android:paddingBottom="4dp"/>
    <EditText android:id="@+id/et_ssid"
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:hint="例如: YEALINK_HOTSPOT 或 Car-WiFi"
        android:inputType="text"
        android:textColor="?android:attr/textColorPrimary"
        android:textColorHint="?android:attr/textColorHint"
        android:background="?android:attr/editTextBackground"
        android:paddingHorizontal="12dp" android:paddingVertical="10dp"
        android:layout_marginBottom="12dp"/>

    <!-- 密码 -->
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="horizontal" android:gravity="center_vertical"
        android:layout_marginBottom="12dp">
        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:orientation="vertical">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Wi-Fi 密码"
                android:textColor="?android:attr/textColorPrimary"
                android:textSize="13sp"
                android:paddingBottom="4dp"/>
            <EditText android:id="@+id/et_password"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:hint="Wi-Fi密码（留空为开放网络）"
                android:inputType="textPassword"
                android:textColor="?android:attr/textColorPrimary"
                android:textColorHint="?android:attr/textColorHint"
                android:background="?android:attr/editTextBackground"
                android:paddingHorizontal="12dp" android:paddingVertical="10dp"/>
        </LinearLayout>
        <CheckBox android:id="@+id/cb_show_password"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="显示"
            android:textColor="?android:attr/textColorPrimary"
            android:paddingStart="8dp"/>
    </LinearLayout>

    <!-- 热点模式 -->
    <CheckBox android:id="@+id/cb_hotspot_mode"
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:text="车机热点模式（亿联车机 Wi-Fi 共享）"
        android:textColor="?android:attr/textColorPrimary"
        android:textSize="13sp"
        android:layout_marginBottom="12dp"/>

    <!-- 重试次数 和 超时 -->
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="horizontal" android:weightSum="2" android:layout_marginBottom="12dp">
        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:orientation="vertical" android:paddingEnd="8dp">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="最大重试次数"
                android:textColor="?android:attr/textColorPrimary"
                android:textSize="13sp"
                android:paddingBottom="4dp"/>
            <EditText android:id="@+id/et_wifi_max_retry"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:text="5" android:inputType="number"
                android:textColor="?android:attr/textColorPrimary"
                android:background="?android:attr/editTextBackground"
                android:paddingHorizontal="12dp" android:paddingVertical="10dp"/>
        </LinearLayout>
        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:orientation="vertical" android:paddingStart="8dp">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="连接超时（秒）"
                android:textColor="?android:attr/textColorPrimary"
                android:textSize="13sp"
                android:paddingBottom="4dp"/>
            <EditText android:id="@+id/et_wifi_timeout"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:text="30" android:inputType="number"
                android:textColor="?android:attr/textColorPrimary"
                android:background="?android:attr/editTextBackground"
                android:paddingHorizontal="12dp" android:paddingVertical="10dp"/>
        </LinearLayout>
    </LinearLayout>

    <!-- 按钮 -->
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="horizontal" android:weightSum="3" android:layout_marginBottom="8dp">
        <Button android:id="@+id/btn_scan_wifi"
            android:layout_width="0dp" android:layout_height="44dp"
            android:layout_weight="1" android:layout_marginEnd="4dp"
            android:text="🔍 扫描" android:textSize="13sp"
            android:backgroundTint="#334499" android:textColor="#FFFFFF"/>
        <Button android:id="@+id/btn_connect_wifi"
            android:layout_width="0dp" android:layout_height="44dp"
            android:layout_weight="1" android:layout_marginHorizontal="4dp"
            android:text="🔗 连接" android:textSize="13sp"
            android:backgroundTint="#1A5A80" android:textColor="#FFFFFF"/>
        <Button android:id="@+id/btn_save_wifi"
            android:layout_width="0dp" android:layout_height="44dp"
            android:layout_weight="1" android:layout_marginStart="4dp"
            android:text="💾 保存" android:textSize="13sp"
            android:backgroundTint="#1A6340" android:textColor="#FFFFFF"/>
    </LinearLayout>

    <!-- 状态 -->
    <TextView android:id="@+id/tv_wifi_scan_status"
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:text="点击【扫描】搜索附近 Wi-Fi 网络"
        android:textColor="?android:attr/textColorSecondary"
        android:textSize="12sp" android:paddingBottom="8dp"/>

    <!-- 网络列表 -->
    <ListView android:id="@+id/lv_wifi_networks"
        android:layout_width="match_parent" android:layout_height="0dp"
        android:layout_weight="1"
        android:background="?android:attr/windowBackground"
        android:dividerHeight="1dp"
        android:divider="?android:attr/listDivider"/>

</LinearLayout>
