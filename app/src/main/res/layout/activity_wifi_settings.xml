<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="?android:attr/windowBackground"
    android:padding="24dp">

    <!-- 标题说明 -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Wi-Fi / 热点设置"
        android:textColor="?android:attr/textColorPrimary"
        android:textSize="18sp"
        android:textStyle="bold"
        android:paddingBottom="8dp"/>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="开启后，蓝牙连接车机时将自动关闭 Wi-Fi 并打开本机热点，让车机连接手机热点上网。"
        android:textColor="?android:attr/textColorSecondary"
        android:textSize="13sp"
        android:lineSpacingExtra="4dp"
        android:paddingBottom="32dp"/>

    <!-- 热点模式开关 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="?android:attr/selectableItemBackground"
        android:padding="12dp"
        android:layout_marginBottom="24dp">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="自动打开热点"
                android:textColor="?android:attr/textColorPrimary"
                android:textSize="15sp"
                android:textStyle="bold"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="蓝牙连接后自动关 Wi-Fi 并开热点"
                android:textColor="?android:attr/textColorSecondary"
                android:textSize="12sp"
                android:paddingTop="2dp"/>
        </LinearLayout>

        <CheckBox
            android:id="@+id/cb_hotspot_mode"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=""
            android:scaleX="1.3"
            android:scaleY="1.3"/>
    </LinearLayout>

    <!-- 状态显示 -->
    <TextView
        android:id="@+id/tv_hotspot_status"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="热点未开启"
        android:textColor="?android:attr/textColorSecondary"
        android:textSize="13sp"
        android:paddingBottom="32dp"/>

    <!-- 保存按钮 -->
    <Button
        android:id="@+id/btn_save_wifi"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:text="💾  保存设置"
        android:textSize="15sp"
        android:backgroundTint="#1A6340"
        android:textColor="#FFFFFF"/>

</LinearLayout>
