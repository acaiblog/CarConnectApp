<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?android:attr/windowBackground"
    android:fillViewport="true">

<LinearLayout
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="16dp">

    <!-- 设备名 -->
    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:text="目标设备名称（支持模糊匹配）"
        android:textColor="?android:attr/textColorPrimary"
        android:textSize="13sp" android:paddingBottom="4dp"/>
    <EditText android:id="@+id/et_device_name"
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:hint="例如: YEALINK 或 车机名称"
        android:inputType="text"
        android:textColor="?android:attr/textColorPrimary"
        android:textColorHint="?android:attr/textColorHint"
        android:background="?android:attr/editTextBackground"
        android:paddingHorizontal="12dp" android:paddingVertical="10dp"
        android:layout_marginBottom="12dp"/>

    <!-- MAC地址 -->
    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:text="目标设备 MAC 地址（精确匹配，优先）"
        android:textColor="?android:attr/textColorPrimary"
        android:textSize="13sp" android:paddingBottom="4dp"/>
    <EditText android:id="@+id/et_device_address"
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:hint="例如: AA:BB:CC:DD:EE:FF"
        android:inputType="text"
        android:textColor="?android:attr/textColorPrimary"
        android:textColorHint="?android:attr/textColorHint"
        android:background="?android:attr/editTextBackground"
        android:paddingHorizontal="12dp" android:paddingVertical="10dp"
        android:layout_marginBottom="12dp"/>

    <!-- 连接参数标题 -->
    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:text="连接参数"
        android:textColor="?android:attr/textColorPrimary"
        android:textSize="13sp" android:textStyle="bold"
        android:paddingBottom="8dp"/>

    <!-- 重试次数 / 超时 / 重试间隔 三列 -->
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="horizontal" android:weightSum="3" android:layout_marginBottom="12dp">

        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:orientation="vertical" android:paddingEnd="4dp">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="最大重试次数"
                android:textColor="?android:attr/textColorPrimary"
                android:textSize="12sp" android:paddingBottom="4dp"/>
            <EditText android:id="@+id/et_max_retry"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:text="5" android:inputType="number"
                android:textColor="?android:attr/textColorPrimary"
                android:background="?android:attr/editTextBackground"
                android:paddingHorizontal="8dp" android:paddingVertical="10dp"/>
        </LinearLayout>

        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:orientation="vertical" android:paddingHorizontal="4dp">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="连接超时（秒）"
                android:textColor="?android:attr/textColorPrimary"
                android:textSize="12sp" android:paddingBottom="4dp"/>
            <EditText android:id="@+id/et_timeout"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:text="30" android:inputType="number"
                android:textColor="?android:attr/textColorPrimary"
                android:background="?android:attr/editTextBackground"
                android:paddingHorizontal="8dp" android:paddingVertical="10dp"/>
        </LinearLayout>

        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:orientation="vertical" android:paddingStart="4dp">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="重试间隔（秒）"
                android:textColor="?android:attr/textColorPrimary"
                android:textSize="12sp" android:paddingBottom="4dp"/>
            <EditText android:id="@+id/et_retry_interval"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:text="5" android:inputType="number"
                android:textColor="?android:attr/textColorPrimary"
                android:background="?android:attr/editTextBackground"
                android:paddingHorizontal="8dp" android:paddingVertical="10dp"/>
        </LinearLayout>
    </LinearLayout>

    <!-- 按钮 -->
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="horizontal" android:weightSum="3" android:layout_marginBottom="16dp">
        <Button android:id="@+id/btn_scan_bt"
            android:layout_width="0dp" android:layout_height="44dp"
            android:layout_weight="1" android:layout_marginEnd="4dp"
            android:text="🔍 扫描" android:textSize="13sp"
            android:backgroundTint="#334499" android:textColor="#FFFFFF"/>
        <Button android:id="@+id/btn_clear_bound"
            android:layout_width="0dp" android:layout_height="44dp"
            android:layout_weight="1" android:layout_marginHorizontal="4dp"
            android:text="🔄 刷新" android:textSize="13sp"
            android:backgroundTint="#555566" android:textColor="#FFFFFF"/>
        <Button android:id="@+id/btn_save_bt"
            android:layout_width="0dp" android:layout_height="44dp"
            android:layout_weight="1" android:layout_marginStart="4dp"
            android:text="💾 保存" android:textSize="13sp"
            android:backgroundTint="#1A6340" android:textColor="#FFFFFF"/>
    </LinearLayout>

    <!-- 状态 -->
    <TextView android:id="@+id/tv_scan_status"
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:text="点击【扫描】发现附近蓝牙设备"
        android:textColor="?android:attr/textColorSecondary"
        android:textSize="12sp" android:paddingBottom="8dp"/>

    <!-- 设备列表 -->
    <ListView android:id="@+id/lv_bt_devices"
        android:layout_width="match_parent"
        android:layout_height="300dp"
        android:background="?android:attr/windowBackground"
        android:dividerHeight="1dp"
        android:divider="?android:attr/listDivider"/>

</LinearLayout>
</ScrollView>
