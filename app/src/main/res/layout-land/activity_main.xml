<?xml version="1.0" encoding="utf-8"?>
<!-- 主界面横屏布局：左列功能控制，右列状态显示 -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="horizontal"
    android:padding="12dp">

    <!-- 左列：功能按钮 + 服务控制（可滚动） -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:orientation="vertical"
        android:paddingEnd="8dp">

        <!-- 标题 + 主题按钮 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingBottom="6dp">
            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="🚗 CarConnect"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="?android:attr/textColorPrimary"/>
            <Button
                android:id="@+id/btn_toggle_theme"
                android:layout_width="wrap_content"
                android:layout_height="32dp"
                android:text="☀ 白色"
                android:textSize="10sp"
                android:paddingHorizontal="10dp"
                android:backgroundTint="#334499"
                android:textColor="#FFFFFF"/>
        </LinearLayout>

        <!-- 可滚动区域 -->
        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:fillViewport="false">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <!-- 功能按钮卡片 -->
                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="6dp"
                    app:cardCornerRadius="8dp"
                    app:cardElevation="3dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="10dp">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="功能设置"
                            android:textSize="12sp"
                            android:textStyle="bold"
                            android:paddingBottom="6dp"/>
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:weightSum="2">
                            <Button
                                android:id="@+id/btn_bluetooth_settings"
                                android:layout_width="0dp"
                                android:layout_height="36dp"
                                android:layout_weight="1"
                                android:layout_marginEnd="4dp"
                                android:text="🔵 蓝牙设置"
                                android:textSize="10sp"
                                android:backgroundTint="@color/colorPrimary"
                                android:textColor="#FFFFFF"/>
                            <Button
                                android:id="@+id/btn_wifi_settings"
                                android:layout_width="0dp"
                                android:layout_height="36dp"
                                android:layout_weight="1"
                                android:layout_marginStart="4dp"
                                android:text="📶 Wi-Fi设置"
                                android:textSize="10sp"
                                android:backgroundTint="@color/colorPrimary"
                                android:textColor="#FFFFFF"/>
                        </LinearLayout>
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:weightSum="2"
                            android:layout_marginTop="4dp">
                            <Button
                                android:id="@+id/btn_app_list"
                                android:layout_width="0dp"
                                android:layout_height="36dp"
                                android:layout_weight="1"
                                android:layout_marginEnd="4dp"
                                android:text="📱 绑定应用"
                                android:textSize="10sp"
                                android:backgroundTint="@color/colorPrimary"
                                android:textColor="#FFFFFF"/>
                            <Button
                                android:id="@+id/btn_log"
                                android:layout_width="0dp"
                                android:layout_height="36dp"
                                android:layout_weight="1"
                                android:layout_marginStart="4dp"
                                android:text="📋 运行日志"
                                android:textSize="10sp"
                                android:backgroundTint="@color/colorPrimary"
                                android:textColor="#FFFFFF"/>
                        </LinearLayout>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- 服务控制卡片 -->
                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="6dp"
                    app:cardCornerRadius="8dp"
                    app:cardElevation="3dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="10dp">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="服务控制"
                            android:textSize="12sp"
                            android:textStyle="bold"
                            android:paddingBottom="6dp"/>
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:weightSum="3">
                            <Button
                                android:id="@+id/btn_start_service"
                                android:layout_width="0dp"
                                android:layout_height="36dp"
                                android:layout_weight="1"
                                android:layout_marginEnd="3dp"
                                android:text="▶ 启动"
                                android:textSize="10sp"
                                android:backgroundTint="#1A6340"
                                android:textColor="#FFFFFF"/>
                            <Button
                                android:id="@+id/btn_manual_scan"
                                android:layout_width="0dp"
                                android:layout_height="36dp"
                                android:layout_weight="1"
                                android:layout_marginHorizontal="3dp"
                                android:text="🔍 扫描"
                                android:textSize="10sp"
                                android:backgroundTint="#334499"
                                android:textColor="#FFFFFF"/>
                            <Button
                                android:id="@+id/btn_stop_scan"
                                android:layout_width="0dp"
                                android:layout_height="36dp"
                                android:layout_weight="1"
                                android:layout_marginStart="3dp"
                                android:text="■ 停止"
                                android:textSize="10sp"
                                android:backgroundTint="#802020"
                                android:textColor="#FFFFFF"/>
                        </LinearLayout>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- 后台间隔 + 开机自启卡片（合并） -->
                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardCornerRadius="8dp"
                    app:cardElevation="3dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="10dp">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="设置"
                            android:textSize="12sp"
                            android:textStyle="bold"
                            android:paddingBottom="6dp"/>
                        <!-- 循环间隔 + 开机自启 同一行 -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="循环间隔"
                                android:textSize="11sp"
                                android:textColor="?android:attr/textColorSecondary"
                                android:layout_marginEnd="6dp"/>
                            <EditText
                                android:id="@+id/et_scan_interval"
                                android:layout_width="50dp"
                                android:layout_height="wrap_content"
                                android:inputType="number"
                                android:maxLength="3"
                                android:textSize="12sp"
                                android:textColor="?android:attr/textColorPrimary"
                                android:gravity="center"
                                android:hint="30"/>
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="秒"
                                android:textSize="11sp"
                                android:textColor="?android:attr/textColorSecondary"
                                android:layout_marginHorizontal="4dp"/>
                            <Button
                                android:id="@+id/btn_save_interval"
                                android:layout_width="wrap_content"
                                android:layout_height="32dp"
                                android:text="保存"
                                android:textSize="10sp"
                                android:paddingHorizontal="10dp"
                                android:backgroundTint="@color/colorPrimary"
                                android:textColor="#FFFFFF"/>
                            <!-- 分隔线 -->
                            <View
                                android:layout_width="1dp"
                                android:layout_height="24dp"
                                android:background="?android:attr/listDivider"
                                android:layout_marginHorizontal="8dp"/>
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="开机自启"
                                android:textSize="11sp"
                                android:textColor="?android:attr/textColorPrimary"
                                android:layout_marginEnd="4dp"/>
                            <android.widget.Switch
                                android:id="@+id/sw_launch_on_boot"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"/>
                        </LinearLayout>
                        <!-- 提示行 -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:paddingTop="2dp">
                            <TextView
                                android:id="@+id/tv_interval_hint"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="当前: 30 秒"
                                android:textSize="10sp"
                                android:textColor="?android:attr/textColorSecondary"/>
                            <TextView
                                android:id="@+id/tv_boot_hint"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="已开启"
                                android:textSize="10sp"
                                android:textColor="?android:attr/textColorSecondary"/>
                        </LinearLayout>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

            </LinearLayout>
        </ScrollView>
    </LinearLayout>

    <!-- 右列：状态显示 -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:orientation="vertical"
        android:paddingStart="8dp">

        <!-- 连接状态卡片 -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            app:cardCornerRadius="10dp"
            app:cardElevation="3dp">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:padding="12dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="连接状态"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:paddingBottom="6dp"/>
                <TextView
                    android:id="@+id/tv_status"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="初始化..."
                    android:textSize="11sp"
                    android:paddingBottom="4dp"/>
                <TextView
                    android:id="@+id/tv_bt_status"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="🔵 蓝牙: 未连接"
                    android:textSize="13sp"
                    android:textColor="#FF6B6B"
                    android:paddingBottom="4dp"/>
                <TextView
                    android:id="@+id/tv_wifi_status"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="📶 Wi-Fi: 等待蓝牙连接..."
                    android:textSize="13sp"
                    android:textColor="#FF6B6B"
                    android:paddingBottom="4dp"/>
                <TextView
                    android:id="@+id/tv_wifi_info"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text=""
                    android:textSize="11sp"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- 说明 -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="💡 开机自动启动 | 后台循环发现蓝牙+Wi-Fi"
            android:textSize="10sp"
            android:gravity="center"
            android:paddingTop="6dp"/>
    </LinearLayout>

</LinearLayout>
